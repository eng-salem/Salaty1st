    ''' <summary>
    ''' Get the first sorted MP3 duaa sound file from the Resources/MP3 folder
    ''' Returns files in DESCENDING order (last file first)
    ''' </summary>
    Private Function GetFirstDuaaSound() As String
        Try
            Dim mp3Folder = System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Resources", "MP3")
            If System.IO.Directory.Exists(mp3Folder) Then
                Dim files = System.IO.Directory.GetFiles(mp3Folder, "*_duaa.mp3")
                If files.Length > 0 Then
                    ' Sort in DESCENDING order and return first file name without extension
                    Array.Sort(files)
                    Array.Reverse(files) ' Reverse to get descending order
                    Dim fileName = System.IO.Path.GetFileNameWithoutExtension(files(0))
                    Console.WriteLine($"[GetFirstDuaaSound] Using first sorted duaa file (DESC): {fileName}")
                    Return fileName
                End If
            End If
        Catch ex As Exception
            Console.WriteLine($"[GetFirstDuaaSound] Error: {ex.Message}")
        End Try
        ' Fallback
        Return "sha3rawy_duaa"
    End Function

