    Private Async Sub CheckForUpdates()
        ' Prevent duplicate checks
        If _updateChecked Then Return
        _updateChecked = True

        Try
            ' Get current version from executable
            Dim currentVersion As Version = GetAppVersion()

            ' Fetch version from GitHub
            Dim client As New Net.Http.HttpClient()
            client.DefaultRequestHeaders.Add("User-Agent", "PrayerWidget")

            Dim json As String = Await client.GetStringAsync("https://raw.githubusercontent.com/eng-salem/Salaty1st/main/version.json")

            ' Parse JSON once into a dictionary
            Dim versionData = ParseJsonToDictionary(json)

            ' Get values from dictionary
            Dim latestVersionStr As String = ""
            Dim downloadUrl As String = ""
            Dim releaseNotes As String = ""
            Dim changelog As String = ""
            Dim screenshotUrl As String = ""

            If versionData.ContainsKey("version") Then latestVersionStr = versionData("version")
            If versionData.ContainsKey("download_url") Then downloadUrl = versionData("download_url")
            If versionData.ContainsKey("release_notes") Then releaseNotes = versionData("release_notes")
            If versionData.ContainsKey("changelog") Then changelog = versionData("changelog")
            If versionData.ContainsKey("screenshot_url") Then screenshotUrl = versionData("screenshot_url")

            Dim latestVersion As New Version(latestVersionStr)

            Console.WriteLine($"Current version: {currentVersion.ToString()}")
            Console.WriteLine($"Latest version: {latestVersion.ToString()}")

            ' Compare versions
            If latestVersion > currentVersion Then
                ' Build changelog message
                Dim changelogMessage As String = ""
                If Not String.IsNullOrEmpty(changelog) Then
                    ' Parse changelog array from JSON
                    Dim changelogItems = ParseJsonArray(json, "changelog")
                    If changelogItems.Count > 0 Then
                        changelogMessage = vbCrLf & vbCrLf & "What's New:" & vbCrLf
                        For Each item In changelogItems
                            changelogMessage &= "• " & item & vbCrLf
                        Next
                    End If
                End If

                Dim result As MessageBoxResult = MessageBox.Show(
                    $"A new version is available!{vbCrLf}{vbCrLf}" &
                    $"Current: {currentVersion.ToString()}{vbCrLf}" &
                    $"Latest: {latestVersion.ToString()}{vbCrLf}" &
                    changelogMessage & vbCrLf &
                    $"Download: setup.exe (Windows Installer){vbCrLf}" &
                    $"After download, run setup.exe to update.{vbCrLf}{vbCrLf}" &
                    $"Would you like to download now?",
                    "Update Available",
                    MessageBoxButton.YesNo,
                    MessageBoxImage.Question)

                If result = MessageBoxResult.Yes Then
                    ' Open download URL only (no screenshot)
                    If Not String.IsNullOrEmpty(downloadUrl) Then
                        Process.Start(downloadUrl)
                    Else
                        Process.Start("https://github.com/eng-salem/Salaty1st/releases/latest")
                    End If
                End If
            Else
                Console.WriteLine("You have the latest version")
            End If
        Catch ex As Exception
            Console.WriteLine("Update check failed: " & ex.Message)
        End Try
    End Sub

    Private Function GetAppVersion() As Version
        Try
            Dim assemblyVersion As Version = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version
            Return New Version(assemblyVersion.Major, assemblyVersion.Minor, assemblyVersion.Build)
        Catch
            Return New Version(1, 0, 0)
        End Try
    End Function

    ''' <summary>
    ''' Parse JSON string into a Dictionary (simple parser for flat JSON objects)
    ''' </summary>
    Private Function ParseJsonToDictionary(json As String) As Dictionary(Of String, String)
        Dim result As New Dictionary(Of String, String)()
        Try
            ' Remove whitespace and braces
            json = json.Trim()
            If json.StartsWith("{") Then json = json.Substring(1)
            If json.EndsWith("}") Then json = json.Substring(0, json.Length - 1)

            ' Simple state machine to parse key-value pairs
            Dim i As Integer = 0
            While i < json.Length
                ' Skip whitespace and commas
                While i < json.Length AndAlso (Char.IsWhiteSpace(json(i)) OrElse json(i) = ","c)
                    i += 1
                End While
                If i >= json.Length Then Exit While

                ' Find key (should be in quotes)
                If json(i) = """"c Then
                    i += 1
                    Dim keyStart As Integer = i
                    While i < json.Length AndAlso json(i) <> """"c
                        i += 1
                    End While
                    Dim key As String = json.Substring(keyStart, i - keyStart)
                    i += 1 ' Skip closing quote

                    ' Skip colon and whitespace
                    While i < json.Length AndAlso (Char.IsWhiteSpace(json(i)) OrElse json(i) = ":"c)
                        i += 1
                    End While

                    ' Find value
                    If i < json.Length Then
                        If json(i) = """"c Then
                            ' String value
                            i += 1
                            Dim valueStart As Integer = i
                            While i < json.Length AndAlso json(i) <> """"c
                                i += 1
                            End While
                            Dim value As String = json.Substring(valueStart, i - valueStart)
                            result(key) = value
                            i += 1 ' Skip closing quote
                        ElseIf json(i) = "["c Then
                            ' Array value - store as JSON string
                            Dim arrayStart As Integer = i
                            Dim bracketCount As Integer = 1
                            i += 1
                            While i < json.Length AndAlso bracketCount > 0
                                If json(i) = "["c Then bracketCount += 1
                                If json(i) = "]"c Then bracketCount -= 1
                                i += 1
                            End While
                            result(key) = json.Substring(arrayStart, i - arrayStart)
                        End If
                    End If
                Else
                    i += 1
                End If
            End While
        Catch ex As Exception
            Console.WriteLine("ParseJsonToDictionary error: " & ex.Message)
        End Try
        Return result
    End Function

    ''' <summary>
    ''' Parse JSON array from JSON string by key
    ''' </summary>
    Private Function ParseJsonArray(json As String, key As String) As List(Of String)
        Dim result As New List(Of String)()
        Try
            ' Find the array in the JSON
            Dim arrayKey As String = """" & key & """:"
            Dim arrayStart As Integer = json.IndexOf(arrayKey)
            If arrayStart < 0 Then Return result

            arrayStart += arrayKey.Length

            ' Find the opening bracket
            While arrayStart < json.Length AndAlso Not Char.IsWhiteSpace(json(arrayStart)) AndAlso json(arrayStart) <> "["c
                arrayStart += 1
            End While

            If arrayStart >= json.Length OrElse json(arrayStart) <> "["c Then Return result

            ' Parse array items
            Dim bracketCount As Integer = 1
            Dim i As Integer = arrayStart + 1
            Dim currentItem As String = ""
            Dim inString As Boolean = False

            While i < json.Length AndAlso bracketCount > 0
                Dim c As Char = json(i)

                If c = """"c Then
                    inString = Not inString
                    currentItem &= c
                ElseIf inString Then
                    currentItem &= c
                ElseIf c = "["c Then
                    bracketCount += 1
                ElseIf c = "]"c Then
                    bracketCount -= 1
                ElseIf c = ","c AndAlso bracketCount = 1 Then
                    ' End of item
                    If Not String.IsNullOrEmpty(currentItem.Trim()) Then
                        ' Remove quotes from string item
                        Dim item = currentItem.Trim().Trim("""")
                        result.Add(item)
                    End If
                    currentItem = ""
                Else
                    currentItem &= c
                End If
                i += 1
            End While

            ' Don't forget the last item
            If Not String.IsNullOrEmpty(currentItem.Trim()) Then
                Dim item = currentItem.Trim().Trim("""")
                result.Add(item)
            End If
        Catch ex As Exception
            Console.WriteLine("ParseJsonArray error: " & ex.Message)
        End Try
        Return result
    End Function

