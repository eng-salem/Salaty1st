        ' Load prayer times from API
        LoadPrayerTimesAsync()

        ' Check if we're very close to the next prayer time (within 30 seconds)
        ' This handles the case where the app starts just before a prayer time
        CheckImmediatePrayerTime()

        ' Show first run message if needed
        If isFirstRun Then
            ShowFirstRunMessage()
        End If
    End Sub

    ''' <summary>
    ''' Check if we're very close to the next prayer time when app starts
    ''' This ensures we don't miss prayer time if app loads just before it
    ''' </summary>
    Private Sub CheckImmediatePrayerTime()
        If _nextPrayerTime = Nothing Then Return

        Dim timeDiff As Double = (_nextPrayerTime - DateTime.Now).TotalSeconds

        ' If we're within 30 seconds of the next prayer time, start the flag
        ' This ensures the timer will catch it
        If timeDiff >= 0 AndAlso timeDiff <= 30 Then
            Console.WriteLine($"[CheckImmediatePrayerTime] Close to prayer time! Diff={timeDiff:F1}s, Prayer={LblPrayer.Text}")
            Console.WriteLine($"[CheckImmediatePrayerTime] Will trigger athan when timer catches it")
            ' Reset flag to ensure we play
            _hasPlayedAthanForCurrentPrayer = False
        End If
    End Sub

    Private Sub SetInitialTabStyles()
        ' Set initial tab colors (Current tab active by default)
        SwitchToCurrentTab()
    End Sub

    Private Function CheckIsFirstRun() As Boolean
        ' Check if user has completed setup (more accurate than checking city)
        Return Not _settings.HasCompletedSetup
    End Function

    Private Sub ShowFirstRunMessage()
        ' First, show language selection dialog
        Dim languageDialog As New LanguageSelectionWindow()
        languageDialog.Owner = Me
        
        If languageDialog.ShowDialog() = True Then
            ' Language selected, reload localization
            InitializeLocalization()
            ApplyTranslations()
        End If
        
        ' Now open settings with first run mode (will auto-detect location)
        ShowSettingsWindow(firstRun:=True)
    End Sub

    Private Sub OpenFacebookPage()
        ' Open Facebook page from version.json
        Dim psi As New ProcessStartInfo("https://www.facebook.com/Salaty.1st") With {
            .UseShellExecute = True
        }
        Process.Start(psi)
    End Sub

    ''' <summary>
    ''' Start the Islamic quote timer
    ''' </summary>
    Private Sub StartQuoteTimer()
        ' Stop existing timer if running
        If _quoteTimer IsNot Nothing Then
            _quoteTimer.Stop()
        End If

        ' Check if quotes are enabled
        Dim enableQuotes As String = _settingsManager.GetSetting("EnableQuotes", "0")
        If enableQuotes <> "1" Then
            Return
        End If

        ' Get interval in minutes
        Dim intervalMinutes As Integer = CInt(_settingsManager.GetSetting("QuoteInterval", "30"))

        ' Start timer
        _quoteTimer = New DispatcherTimer()
        _quoteTimer.Interval = TimeSpan.FromMinutes(intervalMinutes)
        AddHandler _quoteTimer.Tick, AddressOf QuoteTimer_Tick
        _quoteTimer.Start()

        Console.WriteLine($"Quote timer started: every {intervalMinutes} minutes")
    End Sub

    ''' <summary>
    ''' Show a random Islamic quote
    ''' </summary>
    Private Async Sub ShowRandomQuote()
        Try
            Dim quote = Await _quoteService.GetRandomQuote()
            If quote IsNot Nothing Then
                Dim quoteWindow As New QuoteNotificationWindow(quote, 15, True)
                quoteWindow.Owner = Me
                quoteWindow.Show()
                Console.WriteLine($"Quote displayed: {quote.quote.Substring(0, Math.Min(50, quote.quote.Length))}...")
            End If
        Catch ex As Exception
            Console.WriteLine("Error showing quote: " & ex.Message)
        End Try
    End Sub

    Private Sub QuoteTimer_Tick(sender As Object, e As EventArgs)
        ShowRandomQuote()
    End Sub

#Region "Mini Tabs - Current/Previous"

    Private Sub TabCurrent_Click(sender As Object, e As RoutedEventArgs)
        ' Switch to Current tab
        SwitchToCurrentTab()
        ' Reset auto-switch timer
        ResetTabSwitchTimer()
    End Sub

    Private Sub TabPrevious_Click(sender As Object, e As RoutedEventArgs)
        ' Switch to Previous tab
        SwitchToPreviousTab()
        ' Reset auto-switch timer
        ResetTabSwitchTimer()
    End Sub

    Private Sub SwitchToCurrentTab()
        _isCurrentTab = True
        CurrentTabContent.Visibility = Visibility.Visible
        PreviousTabContent.Visibility = Visibility.Collapsed
        
        ' Update tab button styles only
        TabCurrent.Background = New SolidColorBrush(WpfColor.FromRgb(255, 95, 95))
        TabCurrent.Foreground = New SolidColorBrush(WpfColor.FromRgb(255, 255, 255))
        TabPrevious.Background = New SolidColorBrush(WpfColor.FromRgb(45, 58, 74))
        TabPrevious.Foreground = New SolidColorBrush(WpfColor.FromRgb(136, 153, 170))
    End Sub

    Private Sub SwitchToPreviousTab()
        _isCurrentTab = False
        CurrentTabContent.Visibility = Visibility.Collapsed
        PreviousTabContent.Visibility = Visibility.Visible
        
        ' Update tab button styles only
        TabPrevious.Background = New SolidColorBrush(WpfColor.FromRgb(61, 75, 95))
        TabPrevious.Foreground = New SolidColorBrush(WpfColor.FromRgb(255, 255, 255))
        TabCurrent.Background = New SolidColorBrush(WpfColor.FromRgb(45, 58, 74))
        TabCurrent.Foreground = New SolidColorBrush(WpfColor.FromRgb(136, 153, 170))
        
        ' Force elapsed time update immediately
        UpdateElapsedTime()
    End Sub

    Private Sub InitializeTabSwitchTimer()
        _tabSwitchTimer = New DispatcherTimer()
        _tabSwitchTimer.Interval = TimeSpan.FromSeconds(1)
        AddHandler _tabSwitchTimer.Tick, AddressOf TabSwitchTimer_Tick
        _tabSwitchTimer.Start()
    End Sub

    Private Sub TabSwitchTimer_Tick(sender As Object, e As EventArgs)
        _tabSwitchCountdown -= 1

        If _tabSwitchCountdown <= 0 Then
            ' Auto-switch tabs
            If _isCurrentTab Then
                SwitchToPreviousTab()
            Else
                SwitchToCurrentTab()
            End If
            _tabSwitchCountdown = 10
        End If
    End Sub

    Private Sub ResetTabSwitchTimer()
        _tabSwitchCountdown = 10
    End Sub

    Private Sub Window_KeyDown(sender As Object, e As KeyEventArgs)
        ' Ctrl+T to test athan notification
        If e.Key = Key.T AndAlso (Keyboard.Modifiers And ModifierKeys.Control) = ModifierKeys.Control Then
            e.Handled = True
            PlayAthan()
        End If
    End Sub

#End Region
End Class
