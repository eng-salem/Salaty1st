    Private Sub ShowSettingsWindow(Optional firstRun As Boolean = False)
        Dim settingsWindow As New SettingsWindow(_settingsManager, isFirstRun:=firstRun)
        settingsWindow.Owner = Me

        If settingsWindow.ShowDialog() = True Then
            ' Reload settings from database
            _settings = _settingsManager.LoadSettings()
            Dim showWidget As String = _settingsManager.GetSetting("ShowWidget", "1")
            Dim shouldBeVisible As Boolean = (showWidget = "1")

            Console.WriteLine($"After Settings: ShowWidget={showWidget}, shouldBeVisible={shouldBeVisible}, current _widgetVisible={_widgetVisible}")

            ' Apply widget visibility
            If shouldBeVisible <> _widgetVisible Then
                _widgetVisible = shouldBeVisible
            End If

            If _widgetVisible Then
                Me.Show()
                Me.Topmost = True
                Me.Activate()
                Console.WriteLine("Widget shown")
            Else
                Me.Hide()
                Console.WriteLine("Widget hidden")
            End If

            ' Apply all settings changes
            ApplyAllSettingsChanges()

            ' Re-apply translations in case language was changed
            InitializeLocalization()
            UpdateToggleMenuText(If(_widgetVisible, LocalizationService.GetString("hide_widget", "Hide Widget"), LocalizationService.GetString("show_widget_menu", "Show Widget")))
        End If
    End Sub

