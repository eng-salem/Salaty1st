    Private Sub UpdateProgressRing(percentage As Double, remainingSeconds As Double)
        Dim thickness As Double = ProgressArc.StrokeThickness
        If thickness <= 0 Then thickness = 1

        Dim ellipseWidth As Double = ProgressArc.ActualWidth
        If ellipseWidth <= 0 Then ellipseWidth = Me.Width - 16

        Dim radius As Double = (ellipseWidth - thickness) / 2
        If radius <= 0 Then radius = 1

        Dim circumference As Double = 2 * Math.PI * radius
        Dim rawDashLength As Double = circumference * (percentage / 100.0)
        Dim rawGapLength As Double = circumference - rawDashLength
        Dim dashLength As Double = rawDashLength / thickness
        Dim gapLength As Double = rawGapLength / thickness

        ProgressArc.StrokeDashArray = New DoubleCollection({dashLength, gapLength})
        ProgressArc.StrokeDashOffset = 0

        ' Color based on percentage (changes as time progresses)
        If percentage >= 90 Then
            ProgressArc.Stroke = New SolidColorBrush(WpfColor.FromRgb(244, 67, 54)) ' Red (last 10%)
        ElseIf percentage >= 75 Then
            ProgressArc.Stroke = New SolidColorBrush(WpfColor.FromRgb(255, 152, 0)) ' Orange (10-25%)
        ElseIf percentage >= 50 Then
            ProgressArc.Stroke = New SolidColorBrush(WpfColor.FromRgb(255, 193, 7)) ' Yellow (25-50%)
        Else
            ProgressArc.Stroke = New SolidColorBrush(WpfColor.FromRgb(79, 172, 254)) ' Blue (50%+)
        End If
    End Sub

