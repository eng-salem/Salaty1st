    Private Function GetHijriDate() As String
        Try
            ' Use HijriCalendar with adjustment for local moon sighting
            Dim hijriCalendar As New Globalization.HijriCalendar()
            Dim hijriDate As DateTime = DateTime.Now

            ' Get Hijri date components
            Dim day As Integer = hijriCalendar.GetDayOfMonth(hijriDate)
            Dim month As Integer = hijriCalendar.GetMonth(hijriDate)
            Dim year As Integer = hijriCalendar.GetYear(hijriDate)

            ' Apply adjustment from settings (-1, 0, or +1)
            ' Egypt typically needs -1 adjustment for local moon sighting
            day = day + _settings.HijriAdjustment

            ' Handle month boundaries
            If day < 1 Then
                ' Go to previous month
                month = month - 1
                If month < 1 Then
                    month = 12
                    year = year - 1
                End If
                ' Get days in previous month
                Dim daysInPrevMonth As Integer = hijriCalendar.GetDaysInMonth(year, month)
                day = daysInPrevMonth + day ' day is negative
            ElseIf day > 29 Then
                ' Approximate: go to next month (Hijri months are 29-30 days)
                month = month + 1
                If month > 12 Then
                    month = 1
                    year = year + 1
                End If
                day = day - 29
            End If

            ' Month names in English
            Dim monthNames As String() = {
                "Muharram", "Safar", "Rabi' al-Awwal", "Rabi' al-Thani",
                "Jumada al-Awwal", "Jumada al-Thani", "Rajab", "Sha'ban",
                "Ramadan", "Shawwal", "Dhu al-Qi'dah", "Dhu al-Hijjah"
            }

            Return $"{day} {monthNames(month - 1)} {year}"
        Catch ex As Exception
            Return ""
        End Try
    End Function

