    Private Sub PlayAthanForPrayer(prayerName As String)
        WriteLog($"[PlayAthanForPrayer] Starting for: {prayerName}")

        If _settings.AthanSound = "none" Then
            WriteLog("[PlayAthanForPrayer] Athan sound is set to 'none', skipping")
            Console.WriteLine("[PlayAthanForPrayer] Athan sound is set to 'none', skipping")
            Return
        End If

        Try
            WriteLog($"[PlayAthanForPrayer] Called for: {prayerName}")
            Console.WriteLine($"[PlayAthanForPrayer] Called for: {prayerName}")

            ' Determine athan sound based on prayer name
            Dim athanSound As String = _settings.AthanSound

            ' Map "default" to first sorted MP3 file in the folder (ASC)
            If athanSound = "default" Then
                athanSound = GetFirstAthanSound()
            End If

            ' Use per-prayer sound if configured
            Select Case prayerName.ToUpper()
                Case "FAJR"
                    athanSound = If(String.IsNullOrEmpty(_settings.FajrAthanSound), athanSound, _settings.FajrAthanSound)
                Case "DHUHR"
                    athanSound = If(String.IsNullOrEmpty(_settings.DhuhrAthanSound), athanSound, _settings.DhuhrAthanSound)
                Case "ASR"
                    athanSound = If(String.IsNullOrEmpty(_settings.AsrAthanSound), athanSound, _settings.AsrAthanSound)
                Case "MAGHRIB"
                    athanSound = If(String.IsNullOrEmpty(_settings.MaghribAthanSound), athanSound, _settings.MaghribAthanSound)
                Case "ISHA"
                    athanSound = If(String.IsNullOrEmpty(_settings.IshaAthanSound), athanSound, _settings.IshaAthanSound)
            End Select

            ' Map per-prayer "default" to first sorted MP3 file
            If athanSound = "default" Then
                athanSound = GetFirstAthanSound()
            End If

            If athanSound = "none" Then
                Console.WriteLine($"[PlayAthanForPrayer] {prayerName} athan sound is set to 'none', skipping")
                Return
            End If

            ' Load athan sound file from Resources/MP3 folder
            Dim soundPath = System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Resources", "MP3", athanSound & ".mp3")

            Console.WriteLine($"[PlayAthanForPrayer] Prayer: {prayerName}, Sound: {athanSound}, Path: {soundPath}")

            If Not System.IO.File.Exists(soundPath) Then
                Console.WriteLine($"[PlayAthanForPrayer] ERROR: Sound file not found: {soundPath}")
                Console.WriteLine($"[PlayAthanForPrayer] Base directory: {AppDomain.CurrentDomain.BaseDirectory}")

                ' List available MP3 files for debugging
                Try
                    Dim mp3Folder = System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Resources", "MP3")
                    If System.IO.Directory.Exists(mp3Folder) Then
                        Dim files = System.IO.Directory.GetFiles(mp3Folder, "*.mp3")
                        Console.WriteLine($"[PlayAthanForPrayer] Available MP3 files in {mp3Folder}:")
                        For Each f In files
                            Console.WriteLine($"  - {System.IO.Path.GetFileName(f)}")
                        Next
                    Else
                        Console.WriteLine($"[PlayAthanForPrayer] MP3 folder does not exist: {mp3Folder}")
                    End If
                Catch
                End Try

                Return
            End If

            ' Stop any currently playing athan or duaa
            StopAthan()
            StopDuaa()

            ' Set flag indicating athan is playing
            _isAthanPlaying = True

            ' Get volume setting (default 100%)
            Dim volumeSetting As String = _settingsManager.GetSetting("AthanVolume", "100")
            Dim volume As Double = CDbl(volumeSetting)

            Console.WriteLine($"[PlayAthanForPrayer] Opening media file: {soundPath}, Volume: {volume}%")

            ' Show toast notification FIRST with athan sound
            ' The toast will handle its own sound playback
            ShowToastNotification($"🕌 {prayerName} Time",
                                 $"The time for {prayerName} prayer has started.",
                                 soundPath)

            ' Also play sound from main window for reliability
            ' Use MediaPlayer for MP3 playback on UI thread
            Me.Dispatcher.Invoke(Sub()
                _mediaPlayer.Open(New Uri(soundPath))
                _mediaPlayer.Volume = volume ' 0-100 scale from settings

                ' Add error handler for media failures
                AddHandler _mediaPlayer.MediaFailed, Sub(s, e)
                    Console.WriteLine($"[PlayAthanForPrayer] MediaFailed: {e.ErrorException?.Message}")
                    _isAthanPlaying = False
                End Sub

                _mediaPlayer.Play()
                Console.WriteLine($"[PlayAthanForPrayer] Play() called, MediaPlayer state: {_mediaPlayer.Source?.AbsoluteUri}")

                ' Reset flag when playback ends and play duaa if enabled
                AddHandler _mediaPlayer.MediaEnded, Sub(s, e)
                    Console.WriteLine($"[PlayAthanForPrayer] MediaEnded - playback completed")
                    _isAthanPlaying = False
                    ' Play duaa after athan if enabled
                    If _settings.EnableDuaaAfterAthan Then
                        PlayDuaaAfterAthan()
                    End If
                End Sub
            End Sub)

        Catch ex As Exception
            Console.WriteLine($"[PlayAthanForPrayer] ERROR: {ex.GetType().Name}: {ex.Message}")
            Console.WriteLine($"[PlayAthanForPrayer] StackTrace: {ex.StackTrace}")
            _isAthanPlaying = False
        End Try
    End Sub

