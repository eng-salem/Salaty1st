    Private Sub ApplyTranslations()
        ' Context menu items
        If MenuSettings IsNot Nothing Then
            MenuSettings.Header = LocalizationService.GetString("settings_menu", "Settings")
        End If
        If MenuShowAllPrayers IsNot Nothing Then
            MenuShowAllPrayers.Header = LocalizationService.GetString("show_all_prayers", "All Prayer Times")
        End If
        If MenuFacebook IsNot Nothing Then
            MenuFacebook.Header = LocalizationService.GetString("facebook_page", "Facebook Page")
        End If
        If MenuHideWidget IsNot Nothing Then
            MenuHideWidget.Header = LocalizationService.GetString("hide_widget", "Hide Widget")
        End If
        If MenuClose IsNot Nothing Then
            MenuClose.Header = LocalizationService.GetString("close_widget", "Close Widget")
        End If

        ' Notify icon menu items - access through NotifyIcon resource
        Dim notifyIcon As TaskbarIcon = TryCast(FindResource("NotifyIcon"), TaskbarIcon)
        If notifyIcon IsNot Nothing AndAlso notifyIcon.ContextMenu IsNot Nothing Then
            Dim items = notifyIcon.ContextMenu.Items
            If items.Count >= 7 Then
                ' Item 0: Show/Hide Widget
                CType(items(0), MenuItem).Header = LocalizationService.GetString("show_widget_menu", "Show Widget")
                ' Item 2: Settings
                CType(items(2), MenuItem).Header = LocalizationService.GetString("settings_menu", "Settings")
                ' Item 3: All Prayer Times
                CType(items(3), MenuItem).Header = LocalizationService.GetString("show_all_prayers", "All Prayer Times")
                ' Item 5: Facebook Page
                CType(items(5), MenuItem).Header = LocalizationService.GetString("facebook_page", "Facebook Page")
                ' Item 7: Close Widget
                CType(items(7), MenuItem).Header = LocalizationService.GetString("close_widget", "Close Widget")
            End If

            ' Update tooltip
            notifyIcon.ToolTipText = LocalizationService.GetString("prayer_widget", "Prayer Widget")
        End If

        ' Update window title
        Me.Title = LocalizationService.GetString("app_title", "Salaty First")
    End Sub

