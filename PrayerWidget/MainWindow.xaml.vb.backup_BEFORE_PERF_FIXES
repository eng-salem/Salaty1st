    Private Sub UpdateCountdown()
        ' Calculate remaining time to next prayer
        Dim remaining As TimeSpan = _nextPrayerTime - DateTime.Now

        If remaining.TotalSeconds <= 0 Then
            ' Countdown reached zero - prayer time has arrived
            LblCountdown.Text = "00:00:00"
            UpdateProgressRing(100, 0)

            ' Update time since previous prayer
            UpdateTimeSincePrevious()

            ' DON'T reload prayer times here - let Timer_Tick handle the athan trigger first
            ' Reload will happen automatically after athan is triggered (in LoadPrayerTimesAsync)
            ' This prevents the next prayer time from changing before athan can be triggered
            Return
        End If

        ' Update countdown display - use TotalSeconds to handle negative values correctly
        Dim totalSeconds As Integer = CInt(remaining.TotalSeconds)
        Dim hours As Integer = totalSeconds \ 3600
        Dim minutes As Integer = (totalSeconds Mod 3600) \ 60
        Dim seconds As Integer = totalSeconds Mod 60

        LblCountdown.Text = String.Format("{0:D2}:{1:D2}:{2:D2}", hours, minutes, seconds)

        ' Update time since previous prayer
        UpdateTimeSincePrevious()

        ' Calculate percentage based on time between previous and next prayer
        Dim totalDuration As Double = (_nextPrayerTime - _previousPrayerTime).TotalSeconds
        Dim elapsedSeconds As Double = (DateTime.Now - _previousPrayerTime).TotalSeconds
        Dim percent As Double = (elapsedSeconds / totalDuration) * 100
        percent = Math.Min(100, Math.Max(0, percent))

        UpdateProgressRing(percent, remaining.TotalSeconds)
    End Sub

    Private Sub UpdateElapsedTime()
        Dim elapsed As TimeSpan = DateTime.Now - _previousPrayerTime

        ' Format elapsed time as +HH:MM:SS (use Hours not TotalHours to avoid day overflow)
        LblTimeSince.Text = String.Format("+{0:D2}:{1:D2}:{2:D2}",
            elapsed.Hours, elapsed.Minutes, elapsed.Seconds)
    End Sub

    Private Sub UpdateTimeSincePrevious()
        ' Kept for backward compatibility but not used in Timer_Tick
        Dim elapsed As TimeSpan = DateTime.Now - _previousPrayerTime
        LblTimeSince.Text = String.Format("{0:D2}:{1:D2}:{2:D2}",
            elapsed.Hours, elapsed.Minutes, elapsed.Seconds)
    End Sub

