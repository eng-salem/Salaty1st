    Private Sub CheckReminders()
        Dim now As DateTime = DateTime.Now

        ' Only check once per minute
        If (now - _lastReminderCheck).TotalMinutes < 1 Then
            Return
        End If
        _lastReminderCheck = now

        ' Check each prayer reminder (before and after)
        CheckBeforeReminder("Fajr", _currentPrayerTimes.Fajr, _reminderSettings.FajrReminder)
        CheckAfterReminder("Fajr", _currentPrayerTimes.Fajr, _reminderSettings.FajrReminder)

        CheckBeforeReminder("Dhuhr", _currentPrayerTimes.Dhuhr, _reminderSettings.DhuhrReminder)
        CheckAfterReminder("Dhuhr", _currentPrayerTimes.Dhuhr, _reminderSettings.DhuhrReminder)

        CheckBeforeReminder("Asr", _currentPrayerTimes.Asr, _reminderSettings.AsrReminder)
        CheckAfterReminder("Asr", _currentPrayerTimes.Asr, _reminderSettings.AsrReminder)

        CheckBeforeReminder("Maghrib", _currentPrayerTimes.Maghrib, _reminderSettings.MaghribReminder)
        CheckAfterReminder("Maghrib", _currentPrayerTimes.Maghrib, _reminderSettings.MaghribReminder)

        CheckBeforeReminder("Isha", _currentPrayerTimes.Isha, _reminderSettings.IshaReminder)
        CheckAfterReminder("Isha", _currentPrayerTimes.Isha, _reminderSettings.IshaReminder)
    End Sub

    Private Sub CheckBeforeReminder(prayerName As String, prayerTime As DateTime, reminder As PrayerReminder)
        If Not reminder.EnabledBefore Then Return

        Dim reminderKey As String = $"{prayerName}_Before_{prayerTime.Date}"
        If _reminderShown.Contains(reminderKey) Then Return

        Dim timeUntilPrayer As TimeSpan = prayerTime - DateTime.Now
        Dim minutesUntilPrayer As Integer = CInt(timeUntilPrayer.TotalMinutes)

        If minutesUntilPrayer = reminder.MinutesBefore Then
            ShowBeforeReminderNotification(prayerName, reminder.MinutesBefore)
            _reminderShown.Add(reminderKey)
        End If
    End Sub

    Private Sub CheckAfterReminder(prayerName As String, prayerTime As DateTime, reminder As PrayerReminder)
        If Not reminder.EnabledAfter Then Return

        Dim reminderKey As String = $"{prayerName}_After_{prayerTime.Date}"
        If _reminderShown.Contains(reminderKey) Then Return

        Dim timeSincePrayer As TimeSpan = DateTime.Now - prayerTime
        Dim minutesSincePrayer As Integer = CInt(timeSincePrayer.TotalMinutes)

        If minutesSincePrayer = reminder.MinutesAfter Then
            ShowAfterReminderNotification(prayerName, reminder.MinutesAfter)
            _reminderShown.Add(reminderKey)
        End If
    End Sub

