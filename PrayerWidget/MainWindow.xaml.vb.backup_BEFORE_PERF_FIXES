    ' Update LoadPrayerTimesAsync to store prayer times
    Private Async Sub LoadPrayerTimesAsync()
        Dim stackTrace As New System.Diagnostics.StackTrace()
        WriteLog($"=== LoadPrayerTimesAsync START === (called from: {stackTrace.GetFrame(1).GetMethod().Name})")
        WriteLog($"Current time: {DateTime.Now:HH:mm:ss}")
        WriteLog($"Settings: City={_settings.City}, Country={_settings.Country}, SummerTime={_settings.IsSummerTime}")
        
        Try
            Dim prayerTimes = Await _prayerApi.GetPrayerTimesAsync(_settings.City, _settings.Country, _settings.Method, _settings.IsSummerTime, _settings.AsrMethod)

            ' Store for later use
            _currentPrayerTimes = prayerTimes

            _nextPrayerTime = prayerTimes.NextPrayerTime
            _previousPrayerTime = prayerTimes.PreviousPrayerTime

            WriteLog($"Loaded prayer times - Fajr={prayerTimes.Fajr:HH:mm:ss}, Dhuhr={prayerTimes.Dhuhr:HH:mm:ss}, Asr={prayerTimes.Asr:HH:mm:ss}, Maghrib={prayerTimes.Maghrib:HH:mm:ss}, Isha={prayerTimes.Isha:HH:mm:ss}")
            WriteLog($"Next prayer: {prayerTimes.NextPrayer} at {prayerTimes.NextPrayerTime:HH:mm:ss}")

            LblPrayer.Text = prayerTimes.NextPrayer
            LblPreviousName.Text = prayerTimes.PreviousPrayer

            ' Show Hijri date
            LblHijriDate.Text = GetHijriDate()

            ' Update tooltip
            UpdateTooltipText()

            UpdateCountdown()

            ' Log all prayer times for debugging
            Console.WriteLine($"[LoadPrayerTimesAsync] Loaded prayer times:")
            Console.WriteLine($"  Fajr: {prayerTimes.Fajr}")
            Console.WriteLine($"  Dhuhr: {prayerTimes.Dhuhr}")
            Console.WriteLine($"  Asr: {prayerTimes.Asr}")
            Console.WriteLine($"  Maghrib: {prayerTimes.Maghrib}")
            Console.WriteLine($"  Isha: {prayerTimes.Isha}")
            Console.WriteLine($"  Next: {prayerTimes.NextPrayer} at {prayerTimes.NextPrayerTime:HH:mm:ss}")
            Console.WriteLine($"  Previous: {prayerTimes.PreviousPrayer} at {prayerTimes.PreviousPrayerTime:HH:mm:ss}")
            Console.WriteLine($"  Current time: {DateTime.Now:HH:mm:ss}")
            Console.WriteLine($"  Time to next prayer: {(prayerTimes.NextPrayerTime - DateTime.Now).TotalMinutes:F1} minutes")
            Console.WriteLine($"[LoadPrayerTimesAsync] Prayer times loaded - timer will trigger athan at prayer time")
        Catch ex As Exception
            Console.WriteLine("Error loading prayer times: " & ex.Message)
            _nextPrayerTime = DateTime.Now.AddHours(2.5)
            _previousPrayerTime = DateTime.Now.AddHours(-2.5)
            LblPrayer.Text = "ASR"
            LblPreviousName.Text = "DUHR"
            LblHijriDate.Text = GetHijriDate()
            UpdateCountdown()
        End Try
    End Sub

    Private Sub Timer_Tick(sender As Object, e As EventArgs)
        UpdateCountdown()
        UpdateElapsedTime()
        UpdateHijriDate()
        CheckReminders()

        ' Check if it's prayer time
        Dim now As DateTime = DateTime.Now

        ' Use the next prayer time
        Dim targetTime As DateTime = _nextPrayerTime
        Dim timeDiff As Double = (now - targetTime).TotalSeconds

        ' Debug logging every second when near prayer time
        If timeDiff >= -30 AndAlso timeDiff <= 10 Then
            WriteLog($"[Timer_Tick] Debug: target={targetTime:HH:mm:ss}, now={now:HH:mm:ss}, timeDiff={timeDiff:F2}s, flag={_hasPlayedAthanForCurrentPrayer}")
        End If

        ' Trigger athan when we're 0 to 5 seconds AFTER the target prayer time
        If timeDiff >= 0 AndAlso timeDiff <= 5 AndAlso Not _hasPlayedAthanForCurrentPrayer Then
            Dim logMsg1 = $"[Timer_Tick] *** PRAYER TIME REACHED! *** {targetTime:HH:mm:ss}, now={now:HH:mm:ss}, diff={timeDiff:F1}s"
            WriteLog(logMsg1)
            Console.WriteLine(logMsg1)

            WriteLog("[Timer_Tick] Before setting flag")
            _hasPlayedAthanForCurrentPrayer = True
            WriteLog("[Timer_Tick] After setting flag, calling PlayAthan")
            Console.WriteLine("[Timer_Tick] Calling PlayAthan()...")

            PlayAthan()

            ' Reload prayer times for next prayer after athan is triggered
            WriteLog("[Timer_Tick] Calling LoadPrayerTimesAsync for next prayer...")
            LoadPrayerTimesAsync()

            WriteLog("[Timer_Tick] PlayAthan() returned")
            Console.WriteLine("[Timer_Tick] PlayAthan() returned")
        End If

        ' Reset the flag when we're far from the target time (safety reset)
        If timeDiff > 60 OrElse timeDiff < -60 Then
            _hasPlayedAthanForCurrentPrayer = False
        End If
    End Sub

