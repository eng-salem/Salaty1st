    Private Sub ShowToastNotification(title As String, message As String, Optional soundPath As String = Nothing)
        Try
            ' Close any existing toast notifications first
            For Each window In Application.Current.Windows.OfType(Of ToastNotification)()
                window.Close()
            Next

            Dim toast As New ToastNotification(title, message, _settings.NotificationOpacity, _settingsManager, soundPath)
            toast.Owner = Me

            ' Position near system tray (bottom-right corner of screen)
            Dim screenWidth As Double = SystemParameters.WorkArea.Width + SystemParameters.WorkArea.Left
            Dim screenHeight As Double = SystemParameters.WorkArea.Height + SystemParameters.WorkArea.Top
            Dim taskbarHeight As Double = SystemParameters.PrimaryScreenHeight - SystemParameters.WorkArea.Height

            ' Position at bottom-right, above taskbar
            toast.Left = screenWidth - toast.Width - 10
            toast.Top = screenHeight - toast.Height - taskbarHeight - 10

            Console.WriteLine($"[ShowToastNotification] Position: X={toast.Left}, Y={toast.Top}, ScreenSize={screenWidth}x{screenHeight}")
            Console.WriteLine($"[ShowToastNotification] Title='{title}', Message='{message}', SoundPath='{If(soundPath, "None")}'")

            toast.Show()
            Console.WriteLine("[ShowToastNotification] Toast shown successfully")
        Catch ex As Exception
            Console.WriteLine($"[ShowToastNotification] ERROR: {ex.Message}")
        End Try
    End Sub

