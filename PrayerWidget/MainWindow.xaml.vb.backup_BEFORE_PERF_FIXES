    Private Sub UpdateTooltipText()
        Dim notifyIcon As TaskbarIcon = TryCast(FindResource("NotifyIcon"), TaskbarIcon)
        If notifyIcon Is Nothing Then Return

        If _currentPrayerTimes Is Nothing Then
            notifyIcon.ToolTipText = "Loading..."
            Return
        End If

        Dim sb As New System.Text.StringBuilder()
        sb.AppendLine($"{_settings.City}, {_settings.Country}")
        sb.AppendLine($"Fajr: {_currentPrayerTimes.Fajr:hh:mm tt}")
        sb.AppendLine($"Dhuhr: {_currentPrayerTimes.Dhuhr:hh:mm tt}")
        sb.AppendLine($"Asr: {_currentPrayerTimes.Asr:hh:mm tt}")
        sb.AppendLine($"Maghrib: {_currentPrayerTimes.Maghrib:hh:mm tt}")
        sb.AppendLine($"Isha: {_currentPrayerTimes.Isha:hh:mm tt}")
        sb.AppendLine()
        sb.AppendLine($"Next: {_currentPrayerTimes.NextPrayer} in {FormatCountdown(_nextPrayerTime)}")

        ' Windows tooltip has 127 char limit - truncate if needed
        Dim tooltipText As String = sb.ToString()
        If tooltipText.Length > 126 Then
            tooltipText = tooltipText.Substring(0, 126)
        End If

        notifyIcon.ToolTipText = tooltipText
    End Sub

    Private Function FormatCountdown(target As DateTime) As String
        Dim remaining As TimeSpan = target - DateTime.Now
        If remaining.TotalSeconds <= 0 Then
            Return "Now!"
        End If
        ' Return shorter format (HH:MM) for tooltip
        Return String.Format("{0:D2}:{1:D2}", remaining.Hours, remaining.Minutes)
    End Function

