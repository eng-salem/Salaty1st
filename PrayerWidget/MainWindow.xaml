<Window x:Class="MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
    Title="Salaty First"
    Height="180" Width="180"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    MouseRightButtonUp="Window_MouseRightButtonUp"
    Loaded="Window_Loaded"
    Closing="Window_Closing"
    ShowInTaskbar="False"
    ClipToBounds="False"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Taskbar NotifyIcon -->
        <tb:TaskbarIcon x:Key="NotifyIcon"
                        ToolTipText="Prayer Widget"
                        MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Widget" Click="NotifyMenu_ToggleWidget_Click"/>
                    <Separator/>
                    <MenuItem x:Name="NotifyMenuAlwaysOnTop" Header="Always on Top" Click="NotifyMenu_AlwaysOnTop_Click" IsCheckable="True"/>
                    <Separator/>
                    <MenuItem Header="Settings" Click="NotifyMenu_Settings_Click"/>
                    <MenuItem Header="All Prayer Times" Click="NotifyMenu_AllPrayers_Click"/>
                    <Separator/>
                    <MenuItem Header="Facebook Page" Click="NotifyMenu_Facebook_Click"/>
                    <Separator/>
                    <MenuItem Header="Close Widget" Click="NotifyMenu_Close_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Cairo Font Family (Default for all text) -->
        <FontFamily x:Key="Cairo">pack://application:,,,/Resources/#Cairo</FontFamily>

        <!-- Tab Button Style - Tiny Arrows -->
        <Style x:Key="MiniTabButton" TargetType="Button">
            <Setter Property="Background" Value="#2d3a4a"/>
            <Setter Property="Foreground" Value="#8899aa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource Cairo}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3d4a5a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4d5a6a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fade Animation Storyboard -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="8" x:Name="MainGrid">
        <Border CornerRadius="75"
            Background="#1a1a1a"
            BorderBrush="#333333"
            BorderThickness="1"
            x:Name="GlassBorder">
            <Grid>
                <!-- Progress Ring Container -->
                <Grid x:Name="ProgressRingContainer">
                    <!-- Background Ring (Track) -->
                    <Ellipse Stroke="#3d4b5f" StrokeThickness="4" Margin="8"/>

                    <!-- Progress Ring - uses Path with ArcSegment for precise control -->
                    <Path x:Name="ProgressArc"
                        Stroke="#ff5f5f"
                        StrokeThickness="4"
                        StrokeLineJoin="Round"
                        Margin="8"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure x:Name="ProgressArcFigure" StartPoint="0,0" IsClosed="False">
                                    <ArcSegment x:Name="ProgressArcSegment" 
                                        Size="60,60" 
                                        SweepDirection="Clockwise" 
                                        IsLargeArc="False" 
                                        Point="0,0"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                </Grid>

                <!-- Tab Toggle Button - Floating Above -->
                <Button x:Name="TabToggle"
                        Content="⇄"
                        Style="{StaticResource MiniTabButton}"
                        Click="TabToggle_Click"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,35,0,0"
                        Panel.ZIndex="10"/>

                <!-- Content Stack - Centered -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- City/Country (Top - Small) -->
                    <TextBlock x:Name="LblLocation"
                          Text="Cairo, Egypt"
                          Foreground="#888888"
                          FontSize="10"
                          FontFamily="{StaticResource Cairo}"
                          FontWeight="SemiBold"
                          HorizontalAlignment="Center"
                          TextAlignment="Center"
                          Margin="0,0,0,6"
                          TextWrapping="Wrap"/>

                    <!-- Current Tab Content (Countdown) -->
                    <Grid x:Name="CurrentTabContent" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Prayer Name (Large) -->
                            <TextBlock x:Name="LblPrayer"
                                      Text="ASR"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      FontFamily="{StaticResource Cairo}"
                                      Foreground="#ffffff"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,8" Height="46"/>

                            <!-- Countdown Timer (MM:SS format) -->
                            <TextBlock x:Name="LblCountdown"
                                      Text="02:14:55"
                                      FontSize="18"
                                      Foreground="#ffffff"
                                      FontFamily="Consolas"
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"/>

                            <!-- Hijri Date (Bottom) -->
                            <TextBlock x:Name="LblHijriDate"
                                      Text="15 Ramadan 1445"
                                      FontSize="9"
                                      FontFamily="{StaticResource Cairo}"
                                      Foreground="#666666"
                                      HorizontalAlignment="Center"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Previous Tab Content (Count-up) -->
                    <Grid x:Name="PreviousTabContent" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Prayer Name (Large) -->
                            <TextBlock x:Name="LblPreviousName"
                                      Text="DHUHR"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      FontFamily="{StaticResource Cairo}"
                                      Foreground="#ffffff"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,8"
                                      Height="46"/>

                            <!-- Elapsed Time -->
                            <TextBlock x:Name="LblTimeSince"
                                      Text="+2h 14m"
                                      FontSize="18"
                                      Foreground="#ffffff"
                                      FontFamily="Consolas"
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"/>

                            <!-- Hijri Date (Bottom) -->
                            <TextBlock x:Name="LblHijriDate2"
                                      Text="15 Ramadan 1445"
                                      FontSize="9"
                                      FontFamily="{StaticResource Cairo}"
                                      Foreground="#666666"
                                      HorizontalAlignment="Center"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Context Menu -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="MenuSettings" Header="Settings" Click="Menu_Settings_Click"/>
                <MenuItem x:Name="MenuShowAllPrayers" Header="All Prayer Times" Click="Menu_ShowAllPrayers_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuAlwaysOnTop" Header="Always on Top" Click="Menu_AlwaysOnTop_Click" IsCheckable="True"/>
                <Separator/>
                <MenuItem x:Name="MenuFacebook" Header="Facebook Page" Click="Menu_Facebook_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuHideWidget" Header="Hide Widget" Click="Menu_ToggleWidget_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuClose" Header="Close Widget" Click="Menu_Close_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
