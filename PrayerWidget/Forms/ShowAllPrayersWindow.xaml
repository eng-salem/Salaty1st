<Window x:Class="Salaty.First.Forms.ShowAllPrayersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Daily Prayer Times"
    Height="420" Width="360"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <FontFamily x:Key="CairoFont">pack://application:,,,/PrayerWidget;component/Resources/cairo.ttf#Cairo</FontFamily>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="#2A2A2A" BorderBrush="#44FFFFFF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
            </Border.Effect>

            <!-- Rounded corners using Clip -->
            <Border.Clip>
                <RectangleGeometry RadiusX="15" RadiusY="15" Rect="0,0,320,380"/>
            </Border.Clip>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock x:Name="LblTitle" Text="Daily Prayer Times" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LblLocation" Text="Mecca, Saudi Arabia" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock x:Name="LblDate" Text="" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Prayer Times List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                    <StackPanel>

                        <!-- Fajr -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconFajr" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblFajrName" Grid.Column="1" Text="Fajr" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblFajr" Grid.Column="2" Text="05:30" FontSize="16" Foreground="#4FACFE" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Sunrise -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconSunrise" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblSunriseName" Grid.Column="1" Text="Sunrise" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblSunrise" Grid.Column="2" Text="06:45" FontSize="16" Foreground="#FFA500" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Dhuhr -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconDhuhr" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblDhuhrName" Grid.Column="1" Text="Dhuhr" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblDhuhr" Grid.Column="2" Text="12:15" FontSize="16" Foreground="#4FACFE" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Asr -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconAsr" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblAsrName" Grid.Column="1" Text="Asr" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblAsr" Grid.Column="2" Text="15:30" FontSize="16" Foreground="#4FACFE" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Maghrib -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconMaghrib" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblMaghribName" Grid.Column="1" Text="Maghrib" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblMaghrib" Grid.Column="2" Text="18:05" FontSize="16" Foreground="#F4E4C1" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Isha -->
                        <Border Background="#333333" Padding="15" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="IconIsha" Width="20" Height="20" Margin="0,0,10,0" Opacity="0.8"/>
                                <TextBlock x:Name="LblIshaName" Grid.Column="1" Text="Isha" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblIsha" Grid.Column="2" Text="19:30" FontSize="16" Foreground="#F4E4C1" FontFamily="{StaticResource CairoFont}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Close Button -->
                <Button Grid.Row="2" x:Name="BtnClose" Content="Close" Width="120" Padding="10,8"
                        Background="#4FACFE" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnClose_Click" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
