<Window x:Class="LanguageSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Welcome to Salaty First"
    Height="280" Width="420"
    WindowStartupLocation="CenterOwner"
    WindowStyle="SingleBorderWindow"
    ResizeMode="NoResize"
    Background="#1a1a2e">

    <Window.Resources>
        <FontFamily x:Key="SegoeUI">Segoe UI, Tahoma, Arial, sans-serif</FontFamily>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Welcome to Salaty First"
                       FontFamily="{StaticResource SegoeUI}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#ffffff"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Please select your language"
                       FontFamily="{StaticResource SegoeUI}"
                       FontSize="14"
                       FontWeight="Normal"
                       Foreground="#cccccc"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Language ComboBox -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <ComboBox x:Name="LanguageCombo"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      FontFamily="{StaticResource SegoeUI}"
                      FontSize="16"
                      Padding="15,12"
                      Height="50"
                      Background="#16213e"
                      Foreground="#ffffff"
                      BorderBrush="#4FACFE"
                      BorderThickness="2">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Flag}" FontSize="22" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding Name}" Foreground="#ffffff" FontSize="16" FontFamily="{StaticResource SegoeUI}"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#16213e"/>
                        <Setter Property="Foreground" Value="#ffffff"/>
                        <Setter Property="FontFamily" Value="{StaticResource SegoeUI}"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#4FACFE"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>
        </Grid>

        <!-- Continue Button -->
        <Button x:Name="BtnContinue"
                Grid.Row="2"
                Content="Continue"
                Click="BtnContinue_Click"
                HorizontalAlignment="Center"
                Padding="50,14"
                Background="#4FACFE"
                Foreground="#ffffff"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                FontFamily="{StaticResource SegoeUI}"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3D9BF5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
