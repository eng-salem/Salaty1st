<Window x:Class="ToastNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ToastNotification"
    Height="150" Width="360"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    WindowStartupLocation="Manual"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    MouseMove="Window_MouseMove"
    MouseLeftButtonUp="Window_MouseLeftButtonUp"
    LostMouseCapture="Window_LostMouseCapture">

    <Window.Resources>
        <FontFamily x:Key="CairoFont">pack://application:,,,/PrayerWidget;component/Resources/cairo.ttf#Cairo</FontFamily>
        <FontFamily x:Key="SegoeUI">Segoe UI, Tahoma, Arial, sans-serif</FontFamily>
    </Window.Resources>

    <Window.RenderTransform>
        <TranslateTransform x:Name="SwipeTransform" X="0" Y="0"/>
    </Window.RenderTransform>

    <Border x:Name="NotificationBorder" CornerRadius="12" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" Direction="270"/>
        </Border.Effect>
        <Grid Margin="15,12,15,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title and Message -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock x:Name="TitleText"
                          Text="Notification Title"
                          FontSize="14"
                          FontWeight="Bold"
                          FontFamily="{StaticResource SegoeUI}"
                          Foreground="#4FACFE"
                          Margin="0,0,0,4"
                          TextTrimming="CharacterEllipsis"/>

                <TextBlock x:Name="MessageText"
                          Text="Notification message"
                          FontSize="12"
                          FontFamily="{StaticResource SegoeUI}"
                          Foreground="White"
                          TextWrapping="Wrap"
                          TextTrimming="CharacterEllipsis"
                          MaxHeight="48"/>
            </StackPanel>

            <!-- Gear/Settings Icon -->
            <Button x:Name="BtnSettings"
                   Content="⚙"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="White"
                   Background="Transparent"
                   BorderThickness="0"
                   Width="20"
                   Height="20"
                   Grid.Column="1"
                   VerticalAlignment="Top"
                   Cursor="Hand"
                   Click="BtnSettings_Click"
                   ToolTip="Open Settings"
                   Margin="5,0,5,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                                <Setter Property="Foreground" Value="#4FACFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Close Button -->
            <Button x:Name="BtnClose"
                   Content="✕"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#888"
                   Background="Transparent"
                   BorderThickness="0"
                   Width="24"
                   Height="24"
                   Grid.Column="2"
                   VerticalAlignment="Top"
                   Cursor="Hand"
                   Click="BtnClose_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Media Player Controls (hidden by default) -->
            <Border x:Name="MediaControlsBorder" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="#333333" CornerRadius="8" Padding="10" Margin="0,10,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="NowPlayingText"
                              Text="Now Playing: Athan"
                              FontSize="12"
                              FontFamily="{StaticResource CairoFont}"
                              FontStyle="Normal"
                              Foreground="#AAAAAA"
                              Margin="0,0,0,8"
                              TextTrimming="CharacterEllipsis"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Play/Pause Button -->
                        <Button x:Name="BtnPlayPause"
                               Content="⏸"
                               FontSize="18"
                               Foreground="White"
                               Background="#4FACFE"
                               BorderThickness="0"
                               Width="36"
                               Height="36"
                               Cursor="Hand"
                               Click="BtnPlayPause_Click"
                               ToolTip="Play/Pause">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="18"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D8BDF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Progress Bar -->
                        <Slider x:Name="ProgressSlider"
                               Grid.Column="1"
                               Minimum="0" Maximum="100" Value="0"
                               Margin="10,0,10,0"
                               Foreground="#4FACFE"
                               IsEnabled="False"/>

                        <!-- Stop Button -->
                        <Button x:Name="BtnStop"
                               Content="⏹"
                               FontSize="16"
                               Foreground="White"
                               Background="#FF4444"
                               BorderThickness="0"
                               Width="32"
                               Height="32"
                               Grid.Column="2"
                               Cursor="Hand"
                               Click="BtnStop_Click"
                               ToolTip="Stop">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="16"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DD3333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Volume Slider -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🔊" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Slider x:Name="VolumeSlider"
                                   Width="60"
                                   Minimum="0" Maximum="100" Value="100"
                                   Foreground="#4FACFE"
                                   ValueChanged="VolumeSlider_ValueChanged"
                                   ToolTip="Volume"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
