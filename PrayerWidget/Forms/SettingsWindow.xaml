<Window x:Class="SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Widget Settings"
    Height="620" Width="480"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="15,8"
                                Margin="2,0"
                                CornerRadius="5">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4FACFE"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                        Background="#333333"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press">
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            Margin="10,0,30,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            TextBlock.Foreground="White"/>
                            <Path x:Name="Arrow"
                                  Data="M0,0 L4,4 L8,0 Z"
                                  Fill="White"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2A2A2A"
                                            BorderBrush="#444444"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True" Background="#2A2A2A">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4FACFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E8CE6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E7CD6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border CornerRadius="15" Background="#2A2A2A" BorderBrush="#44FFFFFF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Icons/gear.ico" Width="24" Height="24" Margin="0,0,10,0"/>
                        <TextBlock x:Name="LblSettingsTitle" Text="Widget Settings" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <TextBlock x:Name="LblSettingsSubtitle" Text="Customize your prayer widget" FontSize="12" Foreground="#888" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Tabs -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                            Margin="0,0,-25,15" Foreground="White">

                    <!-- Location Tab -->
                    <TabItem x:Name="TabLocation" Header="📍 Location" Style="{StaticResource ModernTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-5,0,0,0">
                            <StackPanel Margin="10">
                                <!-- Location -->
                                <TextBlock x:Name="LblLocationTitle" Text="Location" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>

                                <!-- Address Input with Geocoding -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LblEnterAddress" Text="Search city or use IP location" FontSize="11" Foreground="#AAA"/>
                                            <Button x:Name="BtnIP" Grid.Column="1" Content="📍 Detect My Location"
                                                    Style="{StaticResource ModernButton}" Width="150" Height="35" FontSize="12"
                                                    Click="BtnIP_Click"/>
                                        </Grid>
                                        <TextBlock x:Name="LblGeoStatus" Text="" FontSize="11" Foreground="#4FACFE" Margin="0,5,0,0" TextWrapping="Wrap"/>

                                        <!-- Country ComboBox (searchable) -->
                                        <TextBlock x:Name="LblCountry" Text="Country" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,12,0,8"/>
                                        <ComboBox x:Name="CmbCountry" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"
                                                  IsEditable="True" TextSearch.TextPath="Name"
                                                  SelectionChanged="CmbCountry_SelectionChanged"
                                                  TextElement.Foreground="White">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                                            </ComboBox.Resources>
                                        </ComboBox>

                                        <!-- City ComboBox (searchable, populated when country changes) -->
                                        <TextBlock x:Name="LblCity" Text="City" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbCity" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"
                                                  IsEditable="True" TextSearch.TextPath="Name"
                                                  TextElement.Foreground="White">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- Calculation Method -->
                                <TextBlock x:Name="LblCalculationMethod" Text="Calculation Method" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="CmbMethod" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>

                                <!-- Asr Method -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock x:Name="LblAsrMethod" Text="Asr Method" FontSize="13" Foreground="White"/>
                                        <TextBlock x:Name="LblAsrMethodDesc" Text="Choose juristic method for Asr calculation" FontSize="11" Foreground="#888" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbAsrMethod" Style="{StaticResource ModernComboBox}" Margin="0,0,0,0">
                                            <ComboBoxItem Content="Shafii (Standard)" Tag="0"/>
                                            <ComboBoxItem Content="Hanafi (Later)" Tag="1"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Appearance Tab -->
                    <TabItem x:Name="TabAppearance" Header="🎨 Appearance" Style="{StaticResource ModernTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-5,0,0,0">
                            <StackPanel Margin="10">
                                <!-- Widget Size and Language on same line -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Widget Size -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="LblWidgetSize" Text="Widget Size" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbSize" Style="{StaticResource ModernComboBox}" SelectionChanged="CmbSize_SelectionChanged">
                                            <ComboBoxItem Content="Small (150x150)" Tag="Small"/>
                                            <ComboBoxItem Content="Medium (180x180)" Tag="Medium"/>
                                            <ComboBoxItem Content="Large (240x240)" Tag="Large"/>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <!-- Language -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock x:Name="LblLanguage" Text="Language" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbLanguage" Style="{StaticResource ModernComboBox}" SelectionChanged="CmbLanguage_SelectionChanged"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Appearance -->
                                <TextBlock x:Name="LblAppearanceTitle" Text="Appearance" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>

                                <!-- Widget Opacity -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LblWidgetOpacityTitle" Text="Widget Opacity" FontSize="13" Foreground="White"/>
                                            <TextBlock x:Name="LblWidgetOpacity" Text="70%" FontSize="12" Foreground="#4FACFE" Grid.Column="1"/>
                                        </Grid>
                                        <Slider x:Name="SldWidgetOpacity" Minimum="30" Maximum="100" Value="70"
                                                Margin="0,8,0,0" Foreground="#4FACFE" TickFrequency="5" IsSnapToTickEnabled="True"
                                                ValueChanged="SldWidgetOpacity_ValueChanged"/>
                                    </StackPanel>
                                </Border>

                                <!-- Notification Opacity -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LblNotificationOpacityTitle" Text="Notification Opacity" FontSize="13" Foreground="White"/>
                                            <TextBlock x:Name="LblNotificationOpacity" Text="95%" FontSize="12" Foreground="#4FACFE" Grid.Column="1"/>
                                        </Grid>
                                        <Slider x:Name="SldNotificationOpacity" Minimum="20" Maximum="100" Value="95"
                                                Margin="0,8,0,0" Foreground="#4FACFE" TickFrequency="5" IsSnapToTickEnabled="True"
                                                ValueChanged="SldNotificationOpacity_ValueChanged"/>
                                    </StackPanel>
                                </Border>

                                <!-- Hijri Date Adjustment -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="LblHijriAdjustmentTitle" Text="Hijri Date Adjustment" FontSize="13" Foreground="White"/>
                                                <TextBlock x:Name="LblHijriAdjustmentDesc" Text="Adjust for local moon sighting" FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <TextBlock x:Name="LblHijriAdjustment" Text="0" FontSize="16" FontWeight="Bold" Foreground="#4FACFE" Grid.Column="1"/>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="BtnHijriMinus" Content="−" Width="40" Height="30"
                                                    Background="#444444" Foreground="White" BorderThickness="0"
                                                    Cursor="Hand" Click="BtnHijriAdjustment_Click" Tag="-1"/>
                                            <Slider x:Name="SldHijriAdjustment" Minimum="-1" Maximum="1" Value="0"
                                                    Grid.Column="1" Margin="10,0,10,0" Foreground="#4FACFE"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    ValueChanged="SldHijriAdjustment_ValueChanged"/>
                                            <Button x:Name="BtnHijriPlus" Content="+" Width="40" Height="30"
                                                    Grid.Column="2" Background="#444444" Foreground="White" BorderThickness="0"
                                                    Cursor="Hand" Click="BtnHijriAdjustment_Click" Tag="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Show Progress Ring -->
                                <CheckBox x:Name="ChkShowProgressRing" Content="Show Progress Ring" FontSize="14" Foreground="White" Margin="0,0,0,15">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!-- Show Widget -->
                                <CheckBox x:Name="ChkShowWidget" Content="Show Widget" FontSize="14" Foreground="White" Margin="0,0,0,15">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!-- Summer Time -->
                                <CheckBox x:Name="ChkSummerTime" Content="Summer Time (Add +1 hour)" FontSize="14" Foreground="White" Margin="0,0,0,15">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!-- Start with Windows -->
                                <CheckBox x:Name="ChkStartWithWindows" Content="Start with Windows" FontSize="14" Foreground="White" Margin="0,0,0,15">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!-- Enable Analytics -->
                                <CheckBox x:Name="ChkEnableAnalytics" Content="📊 Enable Anonymous Usage Statistics" FontSize="14" Foreground="White" Margin="0,0,0,15"
                                          IsChecked="True"
                                          ToolTip="Help improve the app by sending anonymous usage data. No personal information is collected.">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Notifications Tab -->
                    <TabItem x:Name="TabNotifications" Header="🔔 Notifications" Style="{StaticResource ModernTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-5,0,0,0">
                            <StackPanel Margin="10">
                                <!-- Athan and Duaa Sound on same line -->
                                <TextBlock x:Name="LblAthanSound" Text="Athan &amp; Duaa Sound" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Athan Sound -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Athan" FontSize="12" Foreground="#AAA" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="CmbSound" Style="{StaticResource ModernComboBox}" Margin="0,0,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Duaa Sound -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Duaa" FontSize="12" Foreground="#AAA" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="CmbDuaaSound" Style="{StaticResource ModernComboBox}" Margin="0,0,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Test Buttons -->
                                    <Button x:Name="BtnTestSound" Grid.Column="4" Content="⏰ Test Athan"
                                            Style="{StaticResource ModernButton}" Width="100" Height="40" FontSize="12"
                                            Click="BtnTestSound_Click" VerticalAlignment="Bottom"/>
                                    <Button x:Name="BtnPlayDuaa" Grid.Column="6" Content="▶ Play Duaa"
                                            Style="{StaticResource ModernButton}" Width="100" Height="40" FontSize="12"
                                            Click="BtnPlayDuaa_Click" VerticalAlignment="Bottom"/>
                                </Grid>

                                <!-- Duaa After Athan Checkbox -->
                                <CheckBox x:Name="ChkEnableDuaaAfterAthan" Content="Play Duaa After Athan" FontSize="14" Foreground="White" Margin="0,0,0,15"
                                          Checked="ChkEnableDuaaAfterAthan_Checked" Unchecked="ChkEnableDuaaAfterAthan_Unchecked">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4"
                                                        Background="#333333" BorderBrush="#4FACFE" BorderThickness="2">
                                                    <Path x:Name="CheckMark" Data="M0,6 L8,14 L18,2" Stroke="#4FACFE" StrokeThickness="3"
                                                          Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#444444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!-- Volume Control -->
                                <Border Background="#333333" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LblAthanVolume" Text="Athan Volume" FontSize="13" Foreground="White"/>
                                            <TextBlock x:Name="LblVolumeValue" Text="100%" FontSize="12" Foreground="#4FACFE" Grid.Column="1"/>
                                        </Grid>
                                        <Slider x:Name="SldAthanVolume" Minimum="0" Maximum="100" Value="100"
                                                Margin="0,8,0,0" Foreground="#4FACFE" TickFrequency="5" IsSnapToTickEnabled="True"
                                                ValueChanged="SldAthanVolume_ValueChanged"/>
                                    </StackPanel>
                                </Border>

                                <!-- Prayer Reminders Section - Compact -->
                                <TextBlock x:Name="LblPrayerReminders" Text="⏰ Prayer Reminders" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>

                                <!-- Compact Prayer Reminders Grid -->
                                <Border Background="#333333" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Prayer" FontSize="12" FontWeight="Bold" Foreground="#AAA" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Column="1" Grid.Row="0" Text="Description" FontSize="12" FontWeight="Bold" Foreground="#AAA" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Column="2" Grid.Row="0" Text="Before" FontSize="12" FontWeight="Bold" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Column="3" Grid.Row="0" Text="After" FontSize="12" FontWeight="Bold" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                        <!-- Fajr Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="Fajr" FontSize="14" FontWeight="Bold" Foreground="#4FACFE" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Column="1" Grid.Row="1" Text="Pre-dawn" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="CmbFajrBefore" Grid.Column="2" Grid.Row="1" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbFajrAfter" Grid.Column="3" Grid.Row="1" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>

                                        <!-- Dhuhr Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Dhuhr" FontSize="14" FontWeight="Bold" Foreground="#FFC107" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Column="1" Grid.Row="2" Text="Midday" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="CmbDhuhrBefore" Grid.Column="2" Grid.Row="2" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbDhuhrAfter" Grid.Column="3" Grid.Row="2" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>

                                        <!-- Asr Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="3" Text="Asr" FontSize="14" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Column="1" Grid.Row="3" Text="Afternoon" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="CmbAsrBefore" Grid.Column="2" Grid.Row="3" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbAsrAfter" Grid.Column="3" Grid.Row="3" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>

                                        <!-- Maghrib Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="4" Text="Maghrib" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Column="1" Grid.Row="4" Text="Sunset" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="CmbMaghribBefore" Grid.Column="2" Grid.Row="4" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbMaghribAfter" Grid.Column="3" Grid.Row="4" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,3">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>

                                        <!-- Isha Row -->
                                        <TextBlock Grid.Column="0" Grid.Row="5" Text="Isha" FontSize="14" FontWeight="Bold" Foreground="#9C27B0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Grid.Row="5" Text="Night" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbIshaBefore" Grid.Column="2" Grid.Row="5" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,0">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbIshaAfter" Grid.Column="3" Grid.Row="5" Style="{StaticResource ModernComboBox}" FontSize="11" Height="26" Margin="2,0,2,0">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <!-- Info Box -->
                                <Border Background="#2A3A4A" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock x:Name="LblHowRemindersWork" Text="ℹ How Reminders Work" FontSize="12" FontWeight="SemiBold" Foreground="#4FACFE"/>
                                        <TextBlock x:Name="LblHowRemindersWorkDesc" Text="Set reminders before and after each prayer time. You'll get a toast notification with sound." FontSize="11" Foreground="#888" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Islamic Quotes Tab -->
                    <TabItem x:Name="TabQuotes" Header="💬 Islamic Quotes" Style="{StaticResource ModernTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-5,0,0,0">
                            <StackPanel Margin="10">
                                <!-- Enable/Disable -->
                                <Border Background="#2A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="💬 Islamic Quotes" FontSize="16" FontWeight="SemiBold" Foreground="#9C27B0"/>
                                                <TextBlock Text="Display inspirational Islamic quotes periodically with audio" FontSize="12" Foreground="#888"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkEnableQuotes" Grid.Column="1" Content="Enable" Foreground="White" FontSize="13" VerticalAlignment="Center" IsChecked="True"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Quote Interval -->
                                <Border Background="#2A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="LblQuoteInterval" Text="Show quote every" FontSize="13" Foreground="White"/>
                                                <TextBlock Text="Select how often to display quotes" FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <ComboBox x:Name="CmbQuoteInterval" Style="{StaticResource ModernComboBox}" Width="100" Margin="0,0,5,0">
                                                    <ComboBoxItem Content="1 min" Tag="1"/>
                                                    <ComboBoxItem Content="5 min" Tag="5"/>
                                                    <ComboBoxItem Content="10 min" Tag="10"/>
                                                    <ComboBoxItem Content="15 min" Tag="15"/>
                                                    <ComboBoxItem Content="30 min" Tag="30"/>
                                                    <ComboBoxItem Content="1 hour" Tag="60"/>
                                                    <ComboBoxItem Content="2 hours" Tag="120"/>
                                                </ComboBox>
                                                <Button x:Name="BtnTestQuote" Content="🧪 Test"
                                                        Style="{StaticResource ModernButton}" Width="70" Height="35" FontSize="12"
                                                        Click="BtnTestQuote_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Audio Settings -->
                                <Border Background="#2A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="🔊 Audio Settings" FontSize="14" FontWeight="SemiBold" Foreground="#9C27B0" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Quote Audio" FontSize="13" Foreground="White"/>
                                                <TextBlock Text="Plays quotes.mp3 when showing quotes" FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkEnableQuoteAudio" Grid.Column="1" Content="Enable Audio" Foreground="White" FontSize="13" VerticalAlignment="Center" IsChecked="True"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Info Box -->
                                <Border Background="#2A3A4A" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="ℹ How It Works" FontSize="12" FontWeight="SemiBold" Foreground="#4FACFE"/>
                                        <TextBlock Text="When enabled, Islamic quotes will be displayed periodically with an audio notification. The quote window appears at the bottom-right of your screen." FontSize="11" Foreground="#888" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button x:Name="BtnCancel" Content="Cancel"
                            Background="#444444" Foreground="White"
                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                            Cursor="Hand" Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="Save and Restart"
                            Background="#4FACFE" Foreground="White"
                            BorderThickness="0" Padding="15,8"
                            Cursor="Hand" Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
